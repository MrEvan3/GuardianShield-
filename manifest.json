{
  "manifest_version": 3,
  "name": "GuardianShield™",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "guardianshield@evandrolemos.com",
      "strict_min_version": "109.0"
    }
  },
  "description": "IA Industrial Contra-Fraude. Unificamos 15 motores e Gemini 2.5 para desmascarar sites falsos e blindar transações em tempo real.",
  "default_locale": "pt_BR",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "alarms",
    "offscreen",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "notifications",
    "downloads",
    "contextMenus",
    "privacy"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pHash.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.google.com/search*",
        "*://*.google.com.br/search*",
        "*://*.google.pt/search*",
        "*://google.com/search*",
        "*://google.com.br/search*"
      ],
      "js": ["google-serp.js"],
      "css": ["google-serp.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GuardianShield™ - Proteção Total"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-eval'; child-src 'self';"
  },
  "options_page": "options.html",
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ads_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["sandbox.html", "report.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
